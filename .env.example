# Core app
NEXT_PUBLIC_APP_NAME=Kinetikos Knowledge Copilot
NODE_ENV=development

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_SCHEMA=public

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=

# Perplexity
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=

# RAG / ingestion settings
RAG_DEFAULT_TENANT=global_kinetikos
RAG_DEFAULT_LANGUAGE=ja
RAG_CHUNK_TARGET_TOKENS=700
RAG_CHUNK_SOFT_MIN_TOKENS=300
RAG_CHUNK_SOFT_MAX_TOKENS=1100
RAG_CHUNK_OVERLAP_RATIO=0.12
RAG_RETRIEVAL_TOP_K=12
RAG_RERANK_TOP_N=6

# Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Dify (if used in parallel with custom app logic)
DIFY_BASE_URL=
DIFY_API_KEY=
DIFY_DATASET_ID=
DIFY_APP_ID=
